# Telegram Bot API token (get from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Telegram chat ID where alerts are sent
TELEGRAM_CHAT_ID=your-chat-id-here

# Optional: Google Maps Directions API key for accurate transit times
# GOOGLE_MAPS_API_KEY=your-key-here

# Search preferences
TARGET_LAT=35.69376
TARGET_LON=139.70343
MAX_RENT=80000
MAX_DISTANCE_KM=20
MIN_MATCH_SCORE=2.0
MAX_TELEGRAM_RESULTS=5

# Optional toggles
# SEND_DAILY_DIGEST=1
# ALERT_REMOVED=1
